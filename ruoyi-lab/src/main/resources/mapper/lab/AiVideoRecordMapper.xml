<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.lab.mapper.AiVideoRecordMapper">
    
    <resultMap type="AiVideoRecord" id="AiVideoRecordResult">
        <result property="recordId"    column="record_id"    />
        <result property="deviceId"    column="device_id"    />
        <result property="recordName"    column="record_name"    />
        <result property="recordPath"    column="record_path"    />
        <result property="recordUrl"    column="record_url"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="duration"    column="duration"    />
        <result property="fileSize"    column="file_size"    />
        <result property="resolution"    column="resolution"    />
        <result property="recordType"    column="record_type"    />
        <result property="status"    column="status"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
        <result property="createBy"    column="create_by"    />
        <result property="updateBy"    column="update_by"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <resultMap id="AiVideoRecordAiDeviceResult" type="AiVideoRecord" extends="AiVideoRecordResult">
        <collection property="aiDeviceList" ofType="AiDevice" column="record_id" select="selectAiDeviceList" />
    </resultMap>

    <resultMap type="AiDevice" id="AiDeviceResult">
        <result property="deviceId"    column="device_id"    />
        <result property="deviceName"    column="device_name"    />
        <result property="rtspUrl"    column="rtsp_url"    />
        <result property="snapshotUrl"    column="snapshot_url"    />
        <result property="identifyInterval"    column="identify_interval"    />
        <result property="alarmInterval"    column="alarm_interval"    />
        <result property="checkStatus"    column="check_status"    />
        <result property="deviceLng"    column="device_lng"    />
        <result property="deviceLat"    column="device_lat"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectAiVideoRecordVo">
        select record_id, device_id, record_name, record_path, record_url, start_time, end_time, duration, file_size, resolution, record_type, status, create_time, update_time, create_by, update_by, remark from ai_video_record
    </sql>

    <select id="selectAiVideoRecordList" parameterType="AiVideoRecord" resultMap="AiVideoRecordResult">
        <include refid="selectAiVideoRecordVo"/>
        <where>  
            <if test="deviceId != null "> and device_id = #{deviceId}</if>
            <if test="recordName != null  and recordName != ''"> and record_name like concat('%', #{recordName}, '%')</if>
            <if test="recordPath != null  and recordPath != ''"> and record_path = #{recordPath}</if>
            <if test="recordUrl != null  and recordUrl != ''"> and record_url = #{recordUrl}</if>
            <if test="startTime != null "> and start_time = #{startTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
            <if test="duration != null "> and duration = #{duration}</if>
            <if test="fileSize != null "> and file_size = #{fileSize}</if>
            <if test="resolution != null  and resolution != ''"> and resolution = #{resolution}</if>
            <if test="recordType != null "> and record_type = #{recordType}</if>
            <if test="status != null "> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectAiVideoRecordByRecordId" parameterType="Long" resultMap="AiVideoRecordAiDeviceResult">
        select record_id, device_id, record_name, record_path, record_url, start_time, end_time, duration, file_size, resolution, record_type, status, create_time, update_time, create_by, update_by, remark
        from ai_video_record
        where record_id = #{recordId}
    </select>

    <select id="selectAiDeviceList" resultMap="AiDeviceResult">
        select device_id, device_name, rtsp_url, snapshot_url, identify_interval, alarm_interval, check_status, device_lng, device_lat, create_time
        from ai_device
        where device_id = #{device_id}
    </select>

    <insert id="insertAiVideoRecord" parameterType="AiVideoRecord" useGeneratedKeys="true" keyProperty="recordId">
        insert into ai_video_record
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">device_id,</if>
            <if test="recordName != null and recordName != ''">record_name,</if>
            <if test="recordPath != null and recordPath != ''">record_path,</if>
            <if test="recordUrl != null">record_url,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="duration != null">duration,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="resolution != null">resolution,</if>
            <if test="recordType != null">record_type,</if>
            <if test="status != null">status,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="createBy != null">create_by,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="deviceId != null">#{deviceId},</if>
            <if test="recordName != null and recordName != ''">#{recordName},</if>
            <if test="recordPath != null and recordPath != ''">#{recordPath},</if>
            <if test="recordUrl != null">#{recordUrl},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="duration != null">#{duration},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="resolution != null">#{resolution},</if>
            <if test="recordType != null">#{recordType},</if>
            <if test="status != null">#{status},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateAiVideoRecord" parameterType="AiVideoRecord">
        update ai_video_record
        <trim prefix="SET" suffixOverrides=",">
            <if test="deviceId != null">device_id = #{deviceId},</if>
            <if test="recordName != null and recordName != ''">record_name = #{recordName},</if>
            <if test="recordPath != null and recordPath != ''">record_path = #{recordPath},</if>
            <if test="recordUrl != null">record_url = #{recordUrl},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="duration != null">duration = #{duration},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="resolution != null">resolution = #{resolution},</if>
            <if test="recordType != null">record_type = #{recordType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where record_id = #{recordId}
    </update>

    <delete id="deleteAiVideoRecordByRecordId" parameterType="Long">
        delete from ai_video_record where record_id = #{recordId}
    </delete>

    <delete id="deleteAiVideoRecordByRecordIds" parameterType="String">
        delete from ai_video_record where record_id in 
        <foreach item="recordId" collection="array" open="(" separator="," close=")">
            #{recordId}
        </foreach>
    </delete>
    
    <delete id="deleteAiDeviceByDeviceIds" parameterType="String">
        delete from ai_device where device_id in 
        <foreach item="deviceId" collection="array" open="(" separator="," close=")">
            #{deviceId}
        </foreach>
    </delete>

    <delete id="deleteAiDeviceByDeviceId" parameterType="Long">
        delete from ai_device where device_id = #{deviceId}
    </delete>

    <insert id="batchAiDevice">
        insert into ai_device( device_id, device_name, rtsp_url, snapshot_url, identify_interval, alarm_interval, check_status, device_lng, device_lat, create_time) values
        <foreach item="item" index="index" collection="list" separator=",">
            ( #{item.deviceId}, #{item.deviceName}, #{item.rtspUrl}, #{item.snapshotUrl}, #{item.identifyInterval}, #{item.alarmInterval}, #{item.checkStatus}, #{item.deviceLng}, #{item.deviceLat}, #{item.createTime})
        </foreach>
    </insert>
</mapper>
    <sql id="selectAiClassScheduleVo">
        select schedule_id, academic_year, week_num, college_name, major_name, grade, class_name, course_name, teacher_name, weekday, section, location, schedule_date, course_order, course_type, course_desc, credits, student_count, status, del_flag, create_by, create_time, update_by, update_time, remark, start_time, end_time from ai_class_schedule
    </sql>

    <select id="selectAiClassScheduleList" parameterType="AiClassSchedule" resultMap="AiClassScheduleResult">
        <include refid="selectAiClassScheduleVo"/>
        <where>  
            <if test="academicYear != null  and academicYear != ''"> and academic_year like concat('%', #{academicYear}, '%')</if>
            <if test="weekNum != null "> and week_num = #{weekNum}</if>
            <if test="collegeName != null  and collegeName != ''"> and college_name like concat('%', #{collegeName}, '%')</if>
            <if test="majorName != null  and majorName != ''"> and major_name like concat('%', #{majorName}, '%')</if>
            <if test="grade != null  and grade != ''"> and grade = #{grade}</if>
            <if test="className != null  and className != ''"> and class_name like concat('%', #{className}, '%')</if>
            <if test="courseName != null  and courseName != ''"> and course_name like concat('%', #{courseName}, '%')</if>
            <if test="teacherName != null  and teacherName != ''"> and teacher_name like concat('%', #{teacherName}, '%')</if>
            <if test="weekday != null "> and weekday = #{weekday}</if>
            <if test="section != null  and section != ''"> and section = #{section}</if>
            <if test="location != null  and location != ''"> and location like concat('%', #{location}, '%')</if>
            <if test="scheduleDate != null "> and schedule_date like concat('%', #{scheduleDate}, '%')</if>
        </where>
    </select>
    
    <select id="selectAiClassScheduleByScheduleId" parameterType="Long" resultMap="AiClassScheduleResult">
